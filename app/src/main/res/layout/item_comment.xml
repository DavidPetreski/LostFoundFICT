<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- Avatar -->
    <TextView
        android:id="@+id/tvCommentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/avatar_background"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Username -->
    <TextView
        android:id="@+id/tvCommentUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/tvCommentAvatar"
        app:layout_constraintStart_toEndOf="@id/tvCommentAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Comment text -->
    <TextView
        android:id="@+id/tvCommentText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvCommentUser"
        app:layout_constraintStart_toEndOf="@id/tvCommentAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tvCommentTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvCommentText"
        app:layout_constraintStart_toEndOf="@id/tvCommentAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>